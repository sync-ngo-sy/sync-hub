# Frontend / public app
# Shared-hosted frontend should only use public-safe env vars.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional override when calling non-Supabase function gateways directly.
VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1
# Public site URL (Auth redirect URLs; optional for local dev)
# VITE_SITE_URL=https://your-jobs.example.com

# Local manual cPanel upload (put secrets in .env.local — never commit passwords)
# CPANEL_FTP_SERVER=sync.ngo
# CPANEL_FTP_USERNAME=subscription@sync.ngo
# CPANEL_FTP_PASSWORD=
# CPANEL_FTP_SERVER_DIR=./
# CPANEL_FTP_PORT=21

# Optional online LLMs for Supabase Edge Functions
# If all providers are unset, backend intent extraction and answer synthesis fall back to deterministic logic.
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
# Required when GEMINI_API_KEY is set (Supabase: supabase secrets set GEMINI_MODEL_ID=gemini-3.5-flash)
GEMINI_MODEL_ID=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=
OLLAMA_EMBEDDING_VERSION=
LLM_TIMEOUT_MS=12000

# Server / worker auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Offline worker auth
# Prefer a worker/device access token. Do not place the service role key on laptops in production.
SUPABASE_ACCESS_TOKEN=your-worker-access-token
# SUPABASE_SERVICE_ROLE_KEY=server-side-only-not-for-laptops

# Worker / offline pipeline
CV_SOURCE_DIR=./cvs
CV_WORKER_TENANT_ID=00000000-0000-0000-0000-000000000000
CV_WORKER_CACHE_DIR=./tmp/cv_intelligence_worker
CV_DELETE_SYNCED_BUNDLES=true
CV_WORKER_UPLOADED_BY=recruiter@example.com
CV_MODEL_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
CV_MODEL_API_KEY=
CV_EXTRACTION_PROVIDER=openai-compatible
CV_EXTRACTION_MODEL=gemini-2.5-flash
CV_EMBEDDING_MODEL=gemini-embedding-001
CV_EMBEDDING_PROVIDER=openai
CV_EMBEDDING_DIMENSION=768
CV_EMBEDDING_VERSION=gemini-embedding-001-768-v1
CV_PARSER_VERSION=v1
CV_MODEL_VERSION=gemini-2.5-flash-v1
CV_PROMPT_VERSION=openai-json-v1
CV_CHUNK_VERSION=v1
CV_ARTIFACT_VERSION=v1
CV_ALLOW_HEURISTIC_FALLBACK=false

# Optional local runtime settings
CV_BATCH_SIZE=8
CV_INGEST_CONCURRENCY=8
CV_EMBEDDING_BATCH_SIZE=16
CV_REQUEST_TIMEOUT_SECONDS=30
CV_SUPABASE_BATCH_SIZE=50
CV_PROGRESS_INTERVAL=25

# Optional Supabase sync settings used by the offline worker
SUPABASE_STORAGE_BUCKET=cv-originals
CV_SYNC_ORIGINALS_TO_STORAGE=false
# Public folder or file URL stored in source_documents.source_uri instead of a local machine path.
CV_PUBLIC_SOURCE_URI=
CV_DEDUPE_SOURCE_DOCUMENTS=true
CV_SUPABASE_PLAN=free
CV_SUPABASE_LIMIT_WARNING_THRESHOLD=0.85
# Override these when the project is not on the default plan-sized quota.
CV_SUPABASE_DATABASE_LIMIT_BYTES=500MiB
CV_SUPABASE_STORAGE_LIMIT_BYTES=1GiB

# Optional Supabase Edge Function secrets for opening private GCS originals.
GCS_ORIGINALS_BUCKET=your-private-cv-bucket
GCS_SIGNED_URL_SERVICE_ACCOUNT_JSON_BASE64=
GCS_SIGNED_URL_EXPIRES_SECONDS=600
