# Staging frontend (dev-jobs.sync.ngo) — copy to .env.staging.local (gitignored).
# Use a separate Supabase project or branch; never point staging at production data.

VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-anon-key
VITE_API_BASE_URL=https://your-staging-project.supabase.co/functions/v1
VITE_SITE_URL=https://dev-jobs.sync.ngo

# Local FTPS upload to staging (optional; GitHub Actions uses STG_* secrets)
# STG_CPANEL_FTP_SERVER=sync.ngo
# STG_CPANEL_FTP_USERNAME=staging@sync.ngo
# STG_CPANEL_FTP_PASSWORD=
# STG_CPANEL_FTP_SERVER_DIR=./
