# frontend-v2 required environment variables.
#
# IMPORTANT: this file is a reference copy only. Vite's actual env file must
# live at the REPO ROOT (../.env), not inside frontend-v2/ — see vite.config.ts's
# `envDir`, which deliberately points one level up so frontend-v2 shares the
# same .env as the rest of the repo (worker/, supabase/, infra/). Copy the
# repo-root `.env.example` to `../.env` and fill it in; this local file exists
# only so the vars this app actually reads are documented next to the code
# that reads them.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
