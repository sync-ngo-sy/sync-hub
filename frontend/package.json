{
  "name": "cv-intelligence-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run check && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit -p tsconfig.app.json",
    "lint": "npm run check",
    "format:check": "node ../scripts/check-repo-format.mjs .",
    "test": "node scripts/test.mjs",
    "check:parsing-overview": "node scripts/check-parsing-overview.mjs",
    "tunnel:sync-dev": "cloudflared tunnel --config ../infra/cloudflare/sync-dev.yml run",
    "tunnel:sync-dev:token": "cloudflared tunnel run --token \"$CLOUDFLARED_TOKEN\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.8",
    "lucide-react": "0.378.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^4.5.5"
  }
}
